{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "YOUR_SUPER_SECRET_KEY_MINIMUM_32_CHARACTERS_LONG_FOR_PRODUCTION",
    "Issuer": "IdentityCore",
    "Audience": "IdentityCore.Microservices",
    "ExpirationMinutes": "60"
  }
}
